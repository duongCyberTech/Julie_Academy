{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "manualRestart": true,
    "assets": [
      { "include": "config/*.json", "watchAssets": true }
    ]
  }
}
